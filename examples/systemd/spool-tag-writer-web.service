[Unit]
Description=Spool Tag Writer Web API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/spool-tag-writer
EnvironmentFile=/home/pi/spool-tag-writer/.env
ExecStart=
ExecStart=/bin/bash -lc '/home/pi/spool-tag-writer/.venv/bin/uvicorn app.main:app --host "${APP_HOST:-0.0.0.0}" --port "${APP_PORT:-8080}"'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target

#!/bin/sh

APP_DIR="${APP_DIR:-/home/lava/printer_data/apps/spool-tag-writer}"
ENV_FILE="$APP_DIR/.env"

if [ -r "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  . "$ENV_FILE"
fi

APP_USER="${APP_USER:-lava}"
APP_STATE_DIR="${APP_STATE_DIR:-/home/lava/printer_data/system/spool-tag-writer}"
PID_FILE="$APP_STATE_DIR/agent.pid"
LOG_FILE="$APP_STATE_DIR/agent.log"
PYTHON_BIN="${PYTHON_BIN:-$APP_DIR/.venv/bin/python}"

is_running() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

start() {
  if is_running; then
    echo "spool-tag-writer-agent already running"
    return 0
  fi

  mkdir -p "$APP_STATE_DIR"
  chown "$APP_USER":"$APP_USER" "$APP_STATE_DIR" 2>/dev/null || true

  su -s /bin/sh "$APP_USER" -c "cd '$APP_DIR' && nohup '$PYTHON_BIN' -m app.moonraker_agent >>'$LOG_FILE' 2>&1 & echo \$! > '$PID_FILE'"
  echo "spool-tag-writer-agent started"
}

stop() {
  if ! is_running; then
    echo "spool-tag-writer-agent not running"
    rm -f "$PID_FILE"
    return 0
  fi

  kill "$(cat "$PID_FILE")" 2>/dev/null || true
  rm -f "$PID_FILE"
  echo "spool-tag-writer-agent stopped"
}

status() {
  if is_running; then
    echo "spool-tag-writer-agent is running (pid $(cat "$PID_FILE"))"
  else
    echo "spool-tag-writer-agent is stopped"
    return 1
  fi
}

case "${1:-}" in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    stop
    start
    ;;
  status)
    status
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac

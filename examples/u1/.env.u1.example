APP_DIR=/home/lava/printer_data/apps/spool-tag-writer
APP_STATE_DIR=/home/lava/printer_data/system/spool-tag-writer
APP_USER=lava

SPOOLMAN_URL=auto
# SPOOLMAN_API_KEY=
SPOOLMAN_API_HEADER=X-API-Key
# Keep verification enabled. Set SPOOLMAN_CA_BUNDLE to your internal CA PEM for custom TLS.
SPOOLMAN_SSL_VERIFY=true
# SPOOLMAN_CA_BUNDLE=/home/lava/printer_data/system/spool-tag-writer/spoolman-ca.pem

APP_HOST=0.0.0.0
APP_PORT=18080

# U1 runs its own RFID readers, so the external ACR122 flow is usually not used here.
LOCAL_NFC_ENABLED=false
NFC_BACKEND=mock
NFC_READER_NAME=ACR122

NTAG215_START_PAGE=4
NTAG215_END_PAGE=129
MOCK_STORAGE_FILE=/tmp/spool-tag-writer.bin
REQUEST_TIMEOUT_SECONDS=10

MOONRAKER_WS_URL=ws://127.0.0.1:7125/websocket
# MOONRAKER_HTTP_URL=http://127.0.0.1:7125
# MOONRAKER_API_KEY=
MOONRAKER_CLIENT_NAME=spool-tag-writer
MOONRAKER_CLIENT_VERSION=0.1.0
MOONRAKER_CLIENT_URL=http://127.0.0.1:18080
MOONRAKER_AGENT_METHOD=spool_tag_writer.write_spool_tag
MOONRAKER_REMOTE_METHOD=spool_tag_writer_write_spool_tag
